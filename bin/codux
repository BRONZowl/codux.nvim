#!/usr/bin/env bash
set -euo pipefail

WINDOW_NAME="${CODUX_WINDOW_NAME:-CODEX}"
CODEX_CMD="${CODEX_CMD:-codex -s workspace-write -a on-request}"

if [ -z "${TMUX:-}" ]; then
  echo "codux: run this from inside tmux" >&2
  exit 1
fi

if tmux list-windows -F '#W' | grep -qx "$WINDOW_NAME"; then
  tmux select-window -t "$WINDOW_NAME"
else
  tmux new-window -n "$WINDOW_NAME" -c "$PWD" "$CODEX_CMD"
fi
